{
  "name": "everydaywriting",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:remote\" \"node server/index.js\"",
    "dev:web": "npm run dev:remote",
    "dev:local": "vite --mode localhost",
    "dev:remote": "vite --mode remote",
    "dev:server": "node server/index.js",
    "build": "tsc -b && vite build",
    "build:local": "tsc -b && vite build --mode localhost",
    "build:remote": "tsc -b && vite build --mode remote",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
